generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  QUANTIFIER
  MANAGER
  AUDITOR
  ADMIN
}

model User {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String
  role         Role   @default(QUANTIFIER)
}

model Formula {
  id         String            @id @default(uuid())
  name       String            @unique
  expression String
  isActive   Boolean           @default(true)
  items      RequisitionItem[]
}

enum ReqStatus {
  PENDING
  FILLING
  COMPLETED
}

model Project {
  id           String        @id @default(uuid())
  name         String
  requisitions Requisition[]
}

model Requisition {
  id             String                     @id @default(uuid())
  projectId      String
  project        Project                    @relation(fields: [projectId], references: [id])
  version        String                     @default("V1")
  status         ReqStatus                  @default(PENDING)
  isReadOnly     Boolean                    @default(false)
  items          RequisitionItem[]
  projectConfigs RequisitionProjectConfig[]
  versionLock    Int                        @default(1)
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
}

enum ItemStatus {
  PENDING
  RECEIVED
}

enum QuantitySourceType {
  PURCHASE
  STOCK_AGP
}

model RequisitionItem {
  id                 String            @id @default(uuid())
  requisitionId      String
  requisition        Requisition       @relation(fields: [requisitionId], references: [id])
  equipmentCatalogId String?
  equipmentCatalog   EquipmentCatalog? @relation(fields: [equipmentCatalogId], references: [id], onDelete: SetNull)
  localName          String?
  operationName      String?
  equipmentCode      String?
  equipmentName      String
  manualQuantity     Float?
  formulaId          String?
  formula            Formula?          @relation(fields: [formulaId], references: [id])
  variablesPayload   Json?
  calculatedValue    Float?
  overrideValue      Float?
  quantitySourceType QuantitySourceType @default(PURCHASE)
  quantitySourceNote String?
  status             ItemStatus        @default(PENDING)
  receivedAt         DateTime?
  receivedById       String?
  observation        String?
  versionLock        Int               @default(1)

  @@index([requisitionId])
}

model ProjectHeaderField {
  id                 String                     @id @default(uuid())
  label              String
  type               ProjectHeaderFieldType     @default(TEXT)
  options            Json?
  defaultValue       String?
  formulaExpression  String?
  sortOrder          Int                        @default(0)
  isActive           Boolean                    @default(true)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  requisitionConfigs RequisitionProjectConfig[]
  autoEquipments     EquipmentCatalog[]
}

model RequisitionProjectConfig {
  id            String             @id @default(uuid())
  requisitionId String
  requisition   Requisition        @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  fieldId       String
  field         ProjectHeaderField @relation(fields: [fieldId], references: [id], onDelete: Restrict)
  value         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([requisitionId, fieldId])
  @@index([requisitionId])
}

model LocalCatalog {
  id        String             @id @default(uuid())
  name      String
  sortOrder Int                @default(0)
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  operations OperationCatalog[]
}

model OperationCatalog {
  id          String             @id @default(uuid())
  localId     String
  local       LocalCatalog       @relation(fields: [localId], references: [id], onDelete: Cascade)
  name        String
  sortOrder   Int                @default(0)
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  equipments  EquipmentCatalog[]

  @@index([localId])
}

model EquipmentCatalog {
  id                String              @id @default(uuid())
  operationId       String
  operation         OperationCatalog    @relation(fields: [operationId], references: [id], onDelete: Cascade)
  code              String
  description       String
  baseQuantity      Float               @default(0)
  autoConfigFieldId String?
  autoConfigField   ProjectHeaderField? @relation(fields: [autoConfigFieldId], references: [id], onDelete: SetNull)
  autoMultiplier    Float               @default(1)
  autoFormulaExpression String?
  sortOrder         Int                 @default(0)
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  requisitionItems  RequisitionItem[]

  @@index([operationId])
  @@index([autoConfigFieldId])
}

enum ProjectHeaderFieldType {
  TEXT
  NUMBER
  SELECT
  COMPUTED
}

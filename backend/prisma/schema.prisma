generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  QUANTIFIER
  MANAGER
  AUDITOR
  ADMIN
}

model User {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String
  role         Role   @default(QUANTIFIER)
}

model Formula {
  id         String            @id @default(uuid())
  name       String            @unique
  expression String
  isActive   Boolean           @default(true)
  items      RequisitionItem[]
}

enum ReqStatus {
  PENDING
  FILLING
  COMPLETED
}

model Project {
  id           String        @id @default(uuid())
  name         String
  requisitions Requisition[]
}

model Requisition {
  id             String                     @id @default(uuid())
  projectId      String
  project        Project                    @relation(fields: [projectId], references: [id])
  version        String                     @default("V1")
  status         ReqStatus                  @default(PENDING)
  isReadOnly     Boolean                    @default(false)
  items          RequisitionItem[]
  projectConfigs RequisitionProjectConfig[]
  versionLock    Int                        @default(1)
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
}

enum ItemStatus {
  PENDING
  RECEIVED
}

model RequisitionItem {
  id               String      @id @default(uuid())
  requisitionId    String
  requisition      Requisition @relation(fields: [requisitionId], references: [id])
  equipmentName    String
  formulaId        String?
  formula          Formula?    @relation(fields: [formulaId], references: [id])
  variablesPayload Json?
  calculatedValue  Float?
  overrideValue    Float?
  status           ItemStatus  @default(PENDING)
  receivedAt       DateTime?
  receivedById     String?
  observation      String?
  versionLock      Int         @default(1)

  @@index([requisitionId])
}

model ProjectHeaderField {
  id                 String                     @id @default(uuid())
  label              String
  sortOrder          Int                        @default(0)
  isActive           Boolean                    @default(true)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  requisitionConfigs RequisitionProjectConfig[]
}

model RequisitionProjectConfig {
  id            String             @id @default(uuid())
  requisitionId String
  requisition   Requisition        @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  fieldId       String
  field         ProjectHeaderField @relation(fields: [fieldId], references: [id], onDelete: Restrict)
  value         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([requisitionId, fieldId])
  @@index([requisitionId])
}

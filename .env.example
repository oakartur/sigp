COMPOSE_PROJECT_NAME=sigp-prd
API_PORT=3000
FRONTEND_PORT=8080

# Banco de dados
DB_USER=postgres
DB_PASSWORD=change_me
DB_NAME=sigp

# Redis
REDIS_HOST=redis-queue
REDIS_PORT=6379

# SMTP
SMTP_HOST=mail.example.com
SMTP_PORT=465
SMTP_USER=no-reply@example.com
SMTP_PASS=change_me

# Seguranca
JWT_SECRET=change_me_with_a_long_random_secret
ALLOW_PUBLIC_REGISTER=false

# Operacao e backup local
BACKUP_KEEP_DAYS=14
BACKUP_KEEP_WEEKS=8
WAL_KEEP_DAYS=7
BACKUP_MAX_AGE_HOURS=8
MAX_DISK_USAGE_PERCENT=80
TZ=America/Cuiaba
